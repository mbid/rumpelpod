                            "null"
                          ]
                        }
                      },
                      "required": [
                        "label",
                        "description"
                      ]
                    }
                  },
                  "multiSelect": {
                    "description": "If true, the user can select multiple options. Default is false (single select).",
                    "type": [
                      "boolean",
                      "null"
                    ],
                    "default": null
                  }
                },
                "required": [
                  "question",
                  "options"
                ]
              }
            }
          },
          "required": [
            "questions"
          ]
        }
      }
    },
