#!/usr/bin/env bash
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
REPO_ROOT="$SCRIPT_DIR/.."
ENV_FILE="$REPO_ROOT/.env"
STATE_DIR="$REPO_ROOT/cloud"
STATE_FILE="$STATE_DIR/eks-state"
KUBECONFIG_PATH="$STATE_DIR/eks-kubeconfig"
CLUSTER_NAME="rumpelpod-test"
REGION="eu-west-1"
ECR_REPO="rumpelpod-test"
NODE_TYPE="t3.small"
NODE_COUNT=1

# Write or update a key=value pair in the .env file.
set_env() {
    local key="$1" value="$2"
    if grep -q "^${key}=" "$ENV_FILE" 2>/dev/null; then
        sed -i "s|^${key}=.*|${key}=${value}|" "$ENV_FILE"
    else
        echo "${key}=${value}" >> "$ENV_FILE"
    fi
}

if [[ -f "$STATE_FILE" ]]; then
    echo "Error: A cluster state file already exists at $STATE_FILE"
    echo "Run deprovision-eks first, or remove the file if the cluster is already gone."
    exit 1
fi

if ! command -v aws &>/dev/null; then
    echo "Error: AWS CLI (aws) is not installed."
    echo "Install it: https://docs.aws.amazon.com/cli/latest/userguide/getting-started-install.html"
    exit 1
fi

if ! command -v eksctl &>/dev/null; then
    echo "Error: eksctl is not installed."
    echo "Install it: https://eksctl.io/installation/"
    exit 1
fi

if ! aws sts get-caller-identity &>/dev/null; then
    echo "Error: AWS credentials not configured. Run 'aws configure' first."
    exit 1
fi

ACCOUNT_ID=$(aws sts get-caller-identity --query Account --output text)
ECR_URI="${ACCOUNT_ID}.dkr.ecr.${REGION}.amazonaws.com/${ECR_REPO}"

mkdir -p "$STATE_DIR"

echo "==> Creating ECR repository $ECR_REPO in $REGION..."
aws ecr create-repository \
    --repository-name "$ECR_REPO" \
    --region "$REGION" \
    >/dev/null

echo "==> Creating EKS cluster $CLUSTER_NAME (type=$NODE_TYPE, nodes=$NODE_COUNT)..."
echo "    This takes 15-20 minutes."
eksctl create cluster \
    --name "$CLUSTER_NAME" \
    --region "$REGION" \
    --node-type "$NODE_TYPE" \
    --nodes "$NODE_COUNT" \
    --managed

# eksctl sets the kubectl context automatically.
KUBE_CONTEXT=$(kubectl config current-context)

# Save the kubeconfig for this cluster separately so it can be
# base64-encoded into .env without touching ~/.kube/config.
eksctl utils write-kubeconfig \
    --cluster "$CLUSTER_NAME" \
    --region "$REGION" \
    --kubeconfig "$KUBECONFIG_PATH"

# EKS managed node groups get AmazonEC2ContainerRegistryReadOnly by
# default, which lets kubelet pull from ECR.  For buildx pushes the
# node role also needs write access.
NODEGROUP_ROLE=$(aws eks describe-nodegroup \
    --cluster-name "$CLUSTER_NAME" \
    --nodegroup-name "$(aws eks list-nodegroups --cluster-name "$CLUSTER_NAME" --region "$REGION" --query 'nodegroups[0]' --output text)" \
    --region "$REGION" \
    --query 'nodegroup.nodeRole' \
    --output text)

echo "==> Granting ECR push access to node role..."
aws iam attach-role-policy \
    --role-name "$(basename "$NODEGROUP_ROLE")" \
    --policy-arn arn:aws:iam::aws:policy/AmazonEC2ContainerRegistryPowerUser

cat > "$STATE_FILE" <<EOF
CLUSTER_NAME=$CLUSTER_NAME
REGION=$REGION
ECR_REPO=$ECR_REPO
ACCOUNT_ID=$ACCOUNT_ID
NODEGROUP_ROLE_NAME=$(basename "$NODEGROUP_ROLE")
EOF

touch "$ENV_FILE"
set_env RUMPELPOD_K8S_KUBECONFIG "$(base64 -w0 "$KUBECONFIG_PATH")"
set_env RUMPELPOD_TEST_K8S_CONTEXT "$KUBE_CONTEXT"
set_env RUMPELPOD_TEST_PUSH_REGISTRY "$ECR_URI"
set_env RUMPELPOD_TEST_PULL_REGISTRY "$ECR_URI"

echo ""
echo "============================================"
echo " EKS cluster ready!"
echo "============================================"
echo " Cluster        : $CLUSTER_NAME"
echo " Region         : $REGION"
echo " ECR repository : $ECR_REPO"
echo " ECR URI        : $ECR_URI"
echo " kubectl context: $KUBE_CONTEXT"
echo " Kubeconfig     : $KUBECONFIG_PATH"
echo ""
echo " State saved to : $STATE_FILE"
echo " Credentials in : $ENV_FILE"
echo ""
echo " .rumpelpod.toml snippet:"
echo ""
echo "   [k8s]"
echo "   context = \"$KUBE_CONTEXT\""
echo "   registry = \"$ECR_URI\""
echo ""
echo " To deprovision : tools/deprovision-eks"
echo ""
