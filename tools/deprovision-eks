#!/usr/bin/env bash
set -euo pipefail

STATE_FILE="$HOME/.eks-cluster"

if [[ ! -f "$STATE_FILE" ]]; then
    echo "Error: No cluster state file found at $STATE_FILE"
    echo "Nothing to deprovision."
    exit 1
fi

# shellcheck source=/dev/null
source "$STATE_FILE"

if [[ -z "${CLUSTER_NAME:-}" || -z "${REGION:-}" ]]; then
    echo "Error: CLUSTER_NAME or REGION not set in $STATE_FILE"
    exit 1
fi

echo "==> Deleting ECR repository ${ECR_REPO:-}..."
if [[ -n "${ECR_REPO:-}" ]]; then
    aws ecr delete-repository \
        --repository-name "$ECR_REPO" \
        --region "$REGION" \
        --force \
        >/dev/null
fi

echo "==> Deleting EKS cluster $CLUSTER_NAME..."
echo "    This takes a few minutes."
eksctl delete cluster \
    --name "$CLUSTER_NAME" \
    --region "$REGION"

# eksctl removes kubeconfig entries on cluster deletion, but clean up
# any leftovers just in case.
kubectl config delete-context "$(kubectl config current-context)" 2>/dev/null || true

rm "$STATE_FILE"

echo ""
echo "============================================"
echo " EKS cluster deprovisioned"
echo "============================================"
echo " Cluster $CLUSTER_NAME and ECR repository ${ECR_REPO:-} deleted."
echo " State file removed: $STATE_FILE"
echo ""
