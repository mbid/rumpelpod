#!/usr/bin/env bash
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
REPO_ROOT="$SCRIPT_DIR/.."
STATE_DIR="$REPO_ROOT/cloud"
STATE_FILE="$STATE_DIR/eks-state"

if [[ ! -f "$STATE_FILE" ]]; then
    echo "Error: No cluster state file found at $STATE_FILE"
    echo "Nothing to deprovision."
    exit 1
fi

# shellcheck source=/dev/null
source "$STATE_FILE"

if [[ -z "${CLUSTER_NAME:-}" || -z "${REGION:-}" ]]; then
    echo "Error: CLUSTER_NAME or REGION not set in $STATE_FILE"
    exit 1
fi

# Remove the ECR push policy we attached during provisioning.
if [[ -n "${NODEGROUP_ROLE_NAME:-}" ]]; then
    echo "==> Detaching ECR push policy from node role..."
    aws iam detach-role-policy \
        --role-name "$NODEGROUP_ROLE_NAME" \
        --policy-arn arn:aws:iam::aws:policy/AmazonEC2ContainerRegistryPowerUser \
        2>/dev/null || true
fi

echo "==> Deleting ECR repository ${ECR_REPO:-}..."
if [[ -n "${ECR_REPO:-}" ]]; then
    aws ecr delete-repository \
        --repository-name "$ECR_REPO" \
        --region "$REGION" \
        --force \
        >/dev/null
fi

echo "==> Deleting EKS cluster $CLUSTER_NAME..."
echo "    This takes a few minutes."
eksctl delete cluster \
    --name "$CLUSTER_NAME" \
    --region "$REGION"

rm -f "$STATE_FILE" "$STATE_DIR/eks-kubeconfig"

echo ""
echo "============================================"
echo " EKS cluster deprovisioned"
echo "============================================"
echo " Cluster $CLUSTER_NAME and ECR repository ${ECR_REPO:-} deleted."
echo " State files removed from $STATE_DIR"
echo ""
echo " Note: RUMPELPOD_* entries in .env are stale and should be"
echo " removed or updated if you provision a new cluster."
echo ""
