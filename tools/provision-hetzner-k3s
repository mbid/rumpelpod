#!/usr/bin/env bash
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
REPO_ROOT="$SCRIPT_DIR/.."
ENV_FILE="$REPO_ROOT/.env"
CONFIG_TEMPLATE="$SCRIPT_DIR/hetzner-k3s-config.yaml"
STATE_DIR="$REPO_ROOT/cloud"
SSH_KEY="${SSH_KEY:-$STATE_DIR/id_ed25519}"

# Write or update a key=value pair in the .env file.
set_env() {
    local key="$1" value="$2"
    if grep -q "^${key}=" "$ENV_FILE" 2>/dev/null; then
        sed -i "s|^${key}=.*|${key}=${value}|" "$ENV_FILE"
    else
        echo "${key}=${value}" >> "$ENV_FILE"
    fi
}

if [[ -z "${HCLOUD_TOKEN:-}" ]]; then
    echo "Error: HCLOUD_TOKEN environment variable is not set."
    echo ""
    echo "Create an API token at:"
    echo "  https://console.hetzner.cloud/ -> your project -> Security -> API Tokens"
    echo ""
    echo "Then: export HCLOUD_TOKEN=<your-token>"
    exit 1
fi

mkdir -p "$STATE_DIR"

if [[ ! -f "$SSH_KEY" ]]; then
    echo "==> Generating SSH keypair at $SSH_KEY..."
    ssh-keygen -t ed25519 -f "$SSH_KEY" -N "" -C "rumpelpod-cloud"
fi
CONFIG="$STATE_DIR/hetzner-k3s-config.yaml"
KUBECONFIG_PATH="$STATE_DIR/hetzner-k3s-kubeconfig"

# Resolve the template into a runtime config with all placeholders
# replaced by actual values.
escape_sed() { printf '%s\n' "$1" | sed 's/[&/\]/\\&/g'; }
sed \
    -e "s|__HCLOUD_TOKEN__|$(escape_sed "$HCLOUD_TOKEN")|" \
    -e "s|__SSH_PUBKEY_PATH__|$(escape_sed "${SSH_KEY}.pub")|" \
    -e "s|__SSH_PRIVKEY_PATH__|$(escape_sed "$SSH_KEY")|" \
    -e "s|__KUBECONFIG_PATH__|$(escape_sed "$KUBECONFIG_PATH")|" \
    "$CONFIG_TEMPLATE" > "$CONFIG"

echo "==> Creating K3s cluster on Hetzner Cloud..."
echo "    This takes 2-3 minutes."
hetzner-k3s create --config "$CONFIG"

export KUBECONFIG="$KUBECONFIG_PATH"

KUBE_CONTEXT=$(KUBECONFIG="$KUBECONFIG_PATH" kubectl config current-context 2>/dev/null || true)

echo "==> Deploying in-cluster registry and builder..."
kubectl apply -f "$SCRIPT_DIR/k8s-registry.yaml"
kubectl apply -f "$SCRIPT_DIR/k8s-builder.yaml"
echo "    Waiting for registry pod..."
kubectl -n registry rollout status deployment/registry --timeout=120s
echo "    Waiting for buildkitd pod..."
kubectl -n buildkit rollout status deployment/buildkitd --timeout=120s

# The in-cluster registry is addressable by its cluster DNS name.
# containerd on each node is configured via registries.yaml to use
# HTTP for this name.  buildkitd is configured the same way so it
# can push directly.
REGISTRY="registry.registry.svc.cluster.local:5000/rumpelpod"

echo ""
echo "============================================"
echo " Hetzner K3s cluster ready!"
echo "============================================"
echo " Kubeconfig       : $KUBECONFIG_PATH"
echo " kubectl context  : ${KUBE_CONTEXT:-<see kubeconfig>}"
echo " Registry (pull)  : $REGISTRY"
echo " Builder          : buildkitd.buildkit (port 1234)"
echo ""
echo " Master (always on):"
echo "   cx33  -- 4 shared vCPU, 8 GB   (~5.49 EUR/month)"
echo ""
echo " Worker pools (scale 0 -> N, idle timeout 1 h):"
echo "   test: cpx32 -- 4 dedicated vCPU, 8 GB   (0-2 nodes)"
echo "   dev:  cpx42 -- 8 dedicated vCPU, 16 GB  (0-1 nodes)"
echo ""
echo " To target a pool, add to your pod spec:"
echo "   nodeSelector:"
echo "     pool: test   # or dev"
echo "   tolerations:"
echo "     - key: pool"
echo "       value: test   # or dev"
echo "       effect: NoSchedule"
echo ""
echo " Privileged containers work out of the box."
echo ""
echo " Usage:"
echo "   export KUBECONFIG=$KUBECONFIG_PATH"
echo ""
touch "$ENV_FILE"
set_env RUMPELPOD_K8S_KUBECONFIG "$(base64 -w0 "$KUBECONFIG_PATH")"
set_env RUMPELPOD_TEST_K8S_CONTEXT "${KUBE_CONTEXT}"
set_env RUMPELPOD_TEST_REGISTRY "$REGISTRY"
set_env RUMPELPOD_TEST_K8S_BUILDER_POD "$(kubectl -n buildkit get pod -l app=buildkitd -o jsonpath='{.items[0].metadata.name}')"
set_env RUMPELPOD_TEST_K8S_BUILDER_NAMESPACE "buildkit"
echo " Cluster credentials written to $ENV_FILE"
echo ""
echo " Inside the devcontainer:"
echo "   cargo xtest -- k8s --ignored"
echo ""
echo " To deprovision:"
echo "   hetzner-k3s delete --config $CONFIG"
echo ""
