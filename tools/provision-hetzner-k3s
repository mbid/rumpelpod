#!/usr/bin/env bash
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
CONFIG_TEMPLATE="$SCRIPT_DIR/hetzner-k3s-config.yaml"
STATE_DIR="$HOME/.hetzner-k3s-cluster"
SSH_KEY="$HOME/.ssh/id_ed25519"

if [[ -d "$STATE_DIR" ]]; then
    echo "Error: Cluster state directory already exists at $STATE_DIR"
    echo "Run deprovision-hetzner-k3s first, or remove the directory if the cluster is already gone."
    exit 1
fi

if [[ -z "${HCLOUD_TOKEN:-}" ]]; then
    echo "Error: HCLOUD_TOKEN environment variable is not set."
    echo ""
    echo "Create an API token at:"
    echo "  https://console.hetzner.cloud/ -> your project -> Security -> API Tokens"
    echo ""
    echo "Then: export HCLOUD_TOKEN=<your-token>"
    exit 1
fi

if [[ ! -f "$SSH_KEY" ]]; then
    echo "Error: SSH key not found at $SSH_KEY"
    exit 1
fi

mkdir -p "$STATE_DIR"
KUBECONFIG_PATH="$STATE_DIR/kubeconfig"

# Resolve the template into a runtime config with all placeholders
# replaced by actual values.
escape_sed() { printf '%s\n' "$1" | sed 's/[&/\]/\\&/g'; }
sed \
    -e "s|__HCLOUD_TOKEN__|$(escape_sed "$HCLOUD_TOKEN")|" \
    -e "s|__SSH_PUBKEY_PATH__|$(escape_sed "${SSH_KEY}.pub")|" \
    -e "s|__SSH_PRIVKEY_PATH__|$(escape_sed "$SSH_KEY")|" \
    -e "s|__KUBECONFIG_PATH__|$(escape_sed "$KUBECONFIG_PATH")|" \
    "$CONFIG_TEMPLATE" > "$STATE_DIR/config.yaml"

echo "==> Creating K3s cluster on Hetzner Cloud..."
echo "    This takes 2-3 minutes."
hetzner-k3s create --config "$STATE_DIR/config.yaml"

export KUBECONFIG="$KUBECONFIG_PATH"

# Tell containerd to use plain HTTP for the in-cluster registry.
# Without this, image pulls fail because containerd defaults to HTTPS.
MASTER_IP=$(kubectl get nodes -o jsonpath='{.items[0].status.addresses[?(@.type=="ExternalIP")].address}')
ssh -o StrictHostKeyChecking=no "root@${MASTER_IP}" bash -s <<'REGISTRIES'
# Deploy an in-cluster container registry.  The pod uses hostPort so
# containerd on the node can pull via localhost:5000.  Tests push via
# kubectl port-forward to the service; pods pull via the cluster-internal
# DNS name, which the registries.yaml mirror redirects to localhost:5000.
echo "==> Deploying in-cluster container registry..."
kubectl apply -f - <<'MANIFEST'
apiVersion: v1
kind: Namespace
metadata:
  name: registry
---
apiVersion: apps/v1
kind: Deployment
metadata:
  name: registry
  namespace: registry
spec:
  replicas: 1
  selector:
    matchLabels:
      app: registry
  template:
    metadata:
      labels:
        app: registry
    spec:
      # Run on the master so the registry is always available, even when
      # all worker nodes have scaled to zero.
      tolerations:
        - key: CriticalAddonsOnly
          operator: Exists
        - key: node-role.kubernetes.io/control-plane
          operator: Exists
        - key: node-role.kubernetes.io/master
          operator: Exists
      nodeSelector:
        node-role.kubernetes.io/control-plane: "true"
      containers:
        - name: registry
          image: registry:2
          ports:
            - containerPort: 5000
              hostPort: 5000
          volumeMounts:
            - name: data
              mountPath: /var/lib/registry
      volumes:
        - name: data
          emptyDir: {}
---
apiVersion: v1
kind: Service
metadata:
  name: registry
  namespace: registry
spec:
  selector:
    app: registry
  ports:
    - port: 5000
      targetPort: 5000
MANIFEST

kubectl -n registry rollout status deployment/registry --timeout=120s

# Tell containerd to pull from the registry pod via localhost:5000 (hostPort)
# when a pod spec references the cluster-internal DNS name.  Without this,
# containerd tries HTTPS and fails.
MASTER_IP=$(kubectl get nodes -o jsonpath='{.items[0].status.addresses[?(@.type=="ExternalIP")].address}')
echo "==> Configuring containerd registry mirror on ${MASTER_IP}..."
ssh -o StrictHostKeyChecking=no "root@${MASTER_IP}" bash -s <<'REGISTRIES'
cat > /etc/rancher/k3s/registries.yaml <<'EOF'
mirrors:
  "registry.registry.svc.cluster.local:5000":
    endpoint:
      - "http://localhost:5000"
EOF
systemctl restart k3s
REGISTRIES

echo "==> Waiting for node to rejoin after k3s restart..."
kubectl wait --for=condition=Ready node --all --timeout=60s

# Persist just enough state for deprovision to work.
cat > "$STATE_DIR/state" <<EOF
KUBECONFIG_PATH=$KUBECONFIG_PATH
EOF

KUBE_CONTEXT=$(KUBECONFIG="$KUBECONFIG_PATH" kubectl config current-context 2>/dev/null || true)

echo ""
echo "============================================"
echo " Hetzner K3s cluster ready!"
echo "============================================"
echo " Kubeconfig       : $KUBECONFIG_PATH"
echo " kubectl context  : ${KUBE_CONTEXT:-<see kubeconfig>}"
echo ""
echo " Master (always on):"
echo "   cx33  -- 4 shared vCPU, 8 GB   (~5.49 EUR/month)"
echo ""
echo " Worker pools (scale 0 -> N, idle timeout 1 h):"
echo "   test: cpx32 -- 4 dedicated vCPU, 8 GB   (0-2 nodes)"
echo "   dev:  cpx42 -- 8 dedicated vCPU, 16 GB  (0-1 nodes)"
echo ""
echo " To target a pool, add to your pod spec:"
echo "   nodeSelector:"
echo "     pool: test   # or dev"
echo "   tolerations:"
echo "     - key: pool"
echo "       value: test   # or dev"
echo "       effect: NoSchedule"
echo ""
echo " Privileged containers work out of the box."
echo ""
echo " In-cluster registry (hostPort on master, not public):"
echo "   Push:  kubectl -n registry port-forward svc/registry 5000:5000 &"
echo "          docker push localhost:5000/REPO/IMAGE:TAG"
echo "   Pull (from inside cluster): registry.registry.svc.cluster.local:5000/REPO/IMAGE:TAG"
echo ""
echo " Usage:"
echo "   export KUBECONFIG=$KUBECONFIG_PATH"
echo ""
echo " To run k8s integration tests:"
echo "   kubectl -n registry port-forward svc/registry 5000:5000 &"
echo "   export RUMPELPOD_TEST_K8S_CONTEXT=${KUBE_CONTEXT:-<see kubeconfig>}"
echo "   export RUMPELPOD_TEST_PUSH_REGISTRY=localhost:5000/rumpelpod"
echo "   export RUMPELPOD_TEST_PULL_REGISTRY=registry.registry.svc.cluster.local:5000/rumpelpod"
echo "   cargo xtest -- k8s --ignored"
echo ""
echo " State saved to  : $STATE_DIR"
echo " To deprovision  : deprovision-hetzner-k3s"
echo ""
