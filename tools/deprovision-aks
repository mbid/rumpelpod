#!/usr/bin/env bash
set -euo pipefail

STATE_FILE="$HOME/.aks-cluster"

if [[ ! -f "$STATE_FILE" ]]; then
    echo "Error: No cluster state file found at $STATE_FILE"
    echo "Nothing to deprovision."
    exit 1
fi

# shellcheck source=/dev/null
source "$STATE_FILE"

if [[ -z "${RESOURCE_GROUP:-}" ]]; then
    echo "Error: RESOURCE_GROUP not set in $STATE_FILE"
    exit 1
fi

echo "==> Deleting resource group $RESOURCE_GROUP (includes cluster + ACR + everything)..."
echo "    This takes a few minutes."
az group delete \
    --name "$RESOURCE_GROUP" \
    --yes \
    --no-wait

# Clean up kubeconfig entries left by az aks get-credentials
KUBE_CONTEXT="${CLUSTER_NAME:-}"
if [[ -n "$KUBE_CONTEXT" ]]; then
    echo "==> Removing kubeconfig entries for context $KUBE_CONTEXT..."
    kubectl config delete-context "$KUBE_CONTEXT" 2>/dev/null || true
    kubectl config delete-cluster "$KUBE_CONTEXT" 2>/dev/null || true
    kubectl config delete-user "clusterUser_${RESOURCE_GROUP}_${KUBE_CONTEXT}" 2>/dev/null || true
fi

rm "$STATE_FILE"

echo ""
echo "============================================"
echo " AKS cluster deprovisioned"
echo "============================================"
echo " Resource group $RESOURCE_GROUP is being deleted (async)."
echo " State file removed: $STATE_FILE"
echo ""
